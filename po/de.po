msgid "Do you want to run '%s' as %s?\n"
msgstr "Möchten Sie '%s' als %s ausführen?\n"

msgid "unknown"
msgstr "unbekannt"

msgid "Root"
msgstr "Root"

msgid "[y/N] "
msgstr "[j/N] "

msgid "[Y/n] "
msgstr "[J/n] "

msgid "Action cancelled.\n"
msgstr "Aktion abgebrochen.\n"

msgid "Unknown user: %s\n"
msgstr "Benutzer nicht gefunden: %s\n"

msgid "Unknown group: %s\n"
msgstr "Gruppe nicht gefunden: %s\n"

msgid "sudo approval plugin version %s\n"
msgstr "Sudo Approval Plugin-Version %s\n"

